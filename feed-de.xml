---
layout: null
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <generator uri="https://jekyllrb.com/">Jekyll</generator>
  <link href="{{ "/feed-de.xml" | absolute_url }}" rel="self" type="application/atom+xml" />
  <link href="{{ "/de/posts" | absolute_url }}" rel="alternate" type="text/html" />
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ "/feed-de.xml" | absolute_url }}</id>
  <title type="html">{{ site.title | escape }} (DE)</title>
  <subtitle>{{ site.description | escape }} - Deutsche Beiträge</subtitle>

  {% assign sorted_posts = site.posts_de | sort: 'date' | reverse %}
  {% for post in sorted_posts limit:20 %}
  <entry>
    <title type="html">{{ post.title | escape }}</title>
    <link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html" title="{{ post.title | escape }}" />
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.date | date_to_xmlschema }}</updated>
    <id>{{ post.url | absolute_url }}</id>
    <content type="html" xml:base="{{ post.url | absolute_url }}">{{ post.content | xml_escape }}</content>
    <author>
      <name>{% if post.author %}{{ post.author }}{% else %}{{ site.author }}{% endif %}</name>
    </author>
    {% for category in post.categories %}
    <category term="{{ category }}" />
    {% endfor %}
    <summary type="html">{{ post.excerpt | strip_html | normalize_whitespace | truncate: 160 | xml_escape }}</summary>
  </entry>
  {% endfor %}
</feed>
